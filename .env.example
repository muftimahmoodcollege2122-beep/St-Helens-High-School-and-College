PORT=5000

# REQUIRED: Strong random JWT secret — run `npm run setup` to auto-generate
# Or generate manually: node -e "require('crypto').randomBytes(48).toString('hex')" 
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# WhatsApp Cloud API (Meta) — optional, leave blank to disable WA alerts
WA_TOKEN=
WA_PHONE_ID=

# JazzCash — leave blank to keep instant-pay disabled (manual payment still works)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_HASH_KEY=
JAZZCASH_RETURN_URL=
JAZZCASH_ENV=sandbox

# EasyPaisa — leave blank to keep instant-pay disabled
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
